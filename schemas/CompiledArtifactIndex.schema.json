{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CompiledArtifactIndex",
  "type": "object",
  "required": [
    "graph_revision_id",
    "workflow_revision_id",
    "policy_bundle_digest",
    "artifact_lifecycle_state",
    "compiler_version",
    "hash_algorithm",
    "canonicalization_version",
    "declared_input_dependency_digests",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "graph_revision_id": {
      "type": "string"
    },
    "workflow_revision_id": {
      "type": "string"
    },
    "policy_bundle_digest": {
      "type": "string"
    },
    "artifact_lifecycle_state": {
      "type": "string"
    },
    "compiler_version": {
      "type": "string"
    },
    "hash_algorithm": {
      "type": "string"
    },
    "canonicalization_version": {
      "type": "string"
    },
    "declared_input_dependency_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "artifact_group",
          "artifact_path",
          "content_digest",
          "hash_algorithm",
          "canonicalization_version"
        ],
        "properties": {
          "artifact_group": {
            "type": "string"
          },
          "artifact_path": {
            "type": "string"
          },
          "content_digest": {
            "type": "string"
          },
          "hash_algorithm": {
            "type": "string"
          },
          "canonicalization_version": {
            "type": "string"
          },
          "revision_id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_name",
          "artifact_path",
          "content_digest"
        ],
        "properties": {
          "artifact_name": {
            "type": "string"
          },
          "artifact_path": {
            "type": "string"
          },
          "content_digest": {
            "type": "string"
          },
          "artifact_revision_id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
