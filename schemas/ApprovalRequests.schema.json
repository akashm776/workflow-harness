{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ApprovalRequests",
  "type": "object",
  "required": [
    "workflow_revision_id",
    "artifact_lifecycle_state",
    "requests"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "workflow_revision_id": {
      "type": "string"
    },
    "artifact_lifecycle_state": {
      "type": "string"
    },
    "requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_id",
          "node_id",
          "approval_subject_hash"
        ],
        "properties": {
          "request_id": {
            "type": "string"
          },
          "node_id": {
            "type": "string"
          },
          "approval_subject_hash": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
