{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RequestedAuth",
  "type": "object",
  "required": [
    "node_id",
    "workflow_revision_id",
    "artifact_lifecycle_state"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "node_id": {
      "type": "string"
    },
    "workflow_revision_id": {
      "type": "string"
    },
    "artifact_lifecycle_state": {
      "type": "string"
    },
    "requested_tools": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool_name": {
            "type": "string"
          },
          "access_mode": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "requested_connectors": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "connector_name": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "requested_permissions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "permission": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
